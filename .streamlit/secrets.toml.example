# Vorlage für Streamlit Cloud Secrets
# In Streamlit Cloud unter Settings → Secrets einfügen (ohne .example)
#
# WICHTIG: Top-Level-Keys ZUERST, [section]-Blöcke ans ENDE.
# In TOML gehören alle Keys nach einer [section]-Zeile zu dieser Section.

# ─── API Keys (Top-Level) ─────────────────────────────────────────────────────
SERPAPI_KEY      = "xxx"
FIRECRAWL_KEY    = "fc-xxx"
PERPLEXITY_KEY   = "pplx-xxx"
ANTHROPIC_KEY    = "sk-ant-xxx"

ZEFIX_USER       = "xxx"
ZEFIX_PASS       = "xxx"

# ─── SMTP (Top-Level) ─────────────────────────────────────────────────────────
SMTP_SERVER      = "smtp.office365.com"
SMTP_PORT        = "587"
SMTP_USER        = "absender@firma.ch"
SMTP_PASS        = "xxx"
EMAIL_FROM       = "absender@firma.ch"

# ─── Login (Section am ENDE!) ─────────────────────────────────────────────────
[auth]
username = "dreierfashion4you"
password = "DEIN-STARKES-PASSWORT-HIER"
name     = "Dreier Fashion4You"
